{
  "name": "alp-monorepo",
  "version": "4.2.0",
  "description": "Autonomous Lifecycle Protocol (ALP) - The universal protocol for autonomous software engineering",
  "private": true,
  "workspaces": [
    "schemas",
    "parser",
    "cli",
    "sdk/*",
    "playground",
    "vscode",
    "docs-site",
    "mcp-server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run build --workspace @alp/parser --workspace @alp/cli && vitest run",
    "test:python": "cd sdk/python && python -m unittest discover -s tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alp-protocol/alp.git"
  },
  "keywords": [
    "alp",
    "protocol",
    "ai",
    "agent",
    "autonomous",
    "software-engineering"
  ],
  "author": "ALP Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alp-protocol/alp/issues"
  },
  "homepage": "https://github.com/alp-protocol/alp#readme",
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
