{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ALP",
  "patterns": [
    { "include": "#version-directive" },
    { "include": "#import-directive" },
    { "include": "#deprecated-directive" },
    { "include": "#assert-directive" },
    { "include": "#if-directive" },
    { "include": "#integrity-directive" },
    { "include": "#comments" },
    { "include": "#separator" },
    { "include": "#block-marker" },
    { "include": "#reference" },
    { "include": "#status" },
    { "include": "#strings" },
    { "include": "#property-directive" },
    { "include": "#property" },
    { "include": "#list-item" },
    { "include": "#numbers" }
  ],
  "repository": {
    "version-directive": {
      "match": "^(!alp-version):\\s*(.+)$",
      "captures": {
        "1": { "name": "keyword.control.directive.alp" },
        "2": { "name": "constant.numeric.version.alp" }
      }
    },
    "import-directive": {
      "match": "^(!import):\\s*(.+)$",
      "captures": {
        "1": { "name": "keyword.control.import.alp" },
        "2": { "name": "string.quoted.double.alp" }
      }
    },
    "deprecated-directive": {
      "match": "^\\s+(!deprecated):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.deprecated.alp" },
        "2": { "name": "string.unquoted.alp" }
      }
    },
    "assert-directive": {
      "match": "^\\s+(!assert):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.assert.alp" },
        "2": { "name": "string.unquoted.alp" }
      }
    },
    "if-directive": {
      "match": "^\\s+(!if):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.if.alp" },
        "2": { "name": "string.unquoted.alp" }
      }
    },
    "integrity-directive": {
      "match": "^\\s+(!integrity):\\s*(.+)$",
      "captures": {
        "1": { "name": "keyword.control.integrity.alp" },
        "2": { "name": "string.quoted.double.alp" }
      }
    },
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.alp"
    },
    "separator": {
      "match": "^---$",
      "name": "punctuation.separator.alp"
    },
    "block-marker": {
      "match": "^(@[a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "captures": {
        "1": { "name": "entity.name.type.alp" }
      }
    },
    "reference": {
      "match": "(->)\\s*([a-zA-Z_][a-zA-Z0-9_-]*)",
      "captures": {
        "1": { "name": "keyword.operator.reference.alp" },
        "2": { "name": "variable.other.reference.alp" }
      }
    },
    "status": {
      "patterns": [
        {
          "match": "\\[x\\]",
          "name": "markup.inserted.status.done.alp"
        },
        {
          "match": "\\[~\\]",
          "name": "markup.changed.status.progress.alp"
        },
        {
          "match": "\\[ \\]",
          "name": "markup.deleted.status.todo.alp"
        },
        {
          "match": "\\[!\\]",
          "name": "invalid.illegal.status.blocked.alp"
        },
        {
          "match": "\\[-\\]",
          "name": "markup.deleted.status.cancelled.alp"
        },
        {
          "match": "\\[\\?\\]",
          "name": "comment.question.status.human-gate.alp"
        }
      ]
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.alp"
    },
    "property-directive": {
      "match": "^\\s+(![a-zA-Z_][a-zA-Z0-9_-]*):\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.directive.alp" },
        "2": { "name": "string.unquoted.alp" }
      }
    },
    "property": {
      "match": "^\\s+([a-zA-Z_][a-zA-Z0-9_]*):\\s*(.*)$",
      "captures": {
        "1": { "name": "support.type.property-name.alp" },
        "2": { "name": "string.unquoted.value.alp" }
      }
    },
    "list-item": {
      "match": "^\\s+-\\s+(.*)$",
      "captures": {
        "1": { "name": "string.unquoted.list-item.alp" }
      }
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.alp"
    }
  },
  "scopeName": "source.alp"
}
