{
  "name": "alp-vscode",
  "displayName": "ALP Language Support",
  "description": "Full language support for the Autonomous Lifecycle Protocol (.alp) — IntelliSense, Go to Definition, Hover, and Diagnostics",
  "version": "16.0.0",
  "publisher": "younglord3302",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/younglord3302/Autonomous-Lifecycle-Protocol-ALP-"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "alp",
        "aliases": [
          "Autonomous Lifecycle Protocol",
          "ALP"
        ],
        "extensions": [
          ".alp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "alp",
        "scopeName": "source.alp",
        "path": "./syntaxes/alp.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "keyword",
        "superType": "keyword",
        "description": "Style for ALP keywords"
      },
      {
        "id": "type",
        "superType": "type",
        "description": "Style for ALP types"
      },
      {
        "id": "variable",
        "superType": "variable",
        "description": "Style for ALP variables/references"
      },
      {
        "id": "property",
        "superType": "property",
        "description": "Style for ALP properties"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "build": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@alp/parser": "*",
    "vscode-languageclient": "^9.0.1"
  }
}
