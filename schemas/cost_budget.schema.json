  "$id": "http://alp-protocol.org/schemas/cost_budget.schema.json",
  "title": "ALP Fine-Grained Token & Cost Budget Object",
  "type": "object",
  "required": ["id", "task_id", "max_tokens", "max_cost_usd"],
  "properties": {
    "id": { "type": "string" },
    "task_id": { "type": "string" },
