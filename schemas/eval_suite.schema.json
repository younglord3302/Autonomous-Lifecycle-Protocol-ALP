{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://alp-protocol.org/schemas/eval_suite.schema.json",
  "title": "ALP Agentic Self-Evaluation & Benchmark Suite Object",
  "type": "object",
  "required": ["id", "target_agent", "test_cases"],
  "properties": {
    "id": { "type": "string" },
    "target_agent": { "type": "string" },
    "metrics": {
      "type": "array",
      "items": { "type": "string", "enum": ["accuracy", "speed", "token_efficiency", "safety", "robustness"] }
    },
    "test_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "input_prompt", "expected_output"],
        "properties": {
          "id": { "type": "string" },
          "input_prompt": { "type": "string" },
          "expected_output": { "type": "string" },
          "weight": { "type": "number" }
        }
      }
    },
    "passing_threshold": { "type": "number" },
    "description": { "type": "string" }
  }
}
