{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://alp-protocol.org/schemas/prompt_optimizer.schema.json",
  "title": "ALP Continuous Self-Improving Prompt & Directive Optimizer Object",
  "type": "object",
  "required": ["id", "target_agent", "base_prompt"],
  "properties": {
    "id": { "type": "string" },
    "target_agent": { "type": "string" },
    "base_prompt": { "type": "string" },
    "optimized_prompt": { "type": "string" },
    "optimization_strategy": {
      "type": "string",
      "enum": ["few_shot", "chain_of_thought", "role_spec", "constraint_hardening", "auto_dpo"]
    },
    "score_improvement": { "type": "number" },
    "iteration": { "type": "number" },
    "description": { "type": "string" }
  }
}
