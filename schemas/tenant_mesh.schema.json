{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://alp-protocol.org/schemas/tenant_mesh.schema.json",
  "title": "ALP Multi-Tenant Enterprise Mesh Object",
  "type": "object",
  "required": ["id", "tenant_id", "org_name"],
  "properties": {
    "id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "org_name": { "type": "string" },
    "sso_provider": { "type": "string" },
    "max_workspaces": { "type": "number" },
    "rbac_roles": {
      "type": "object"
    },
    "description": { "type": "string" }
  }
}
