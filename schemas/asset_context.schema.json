  "$id": "http://alp-protocol.org/schemas/asset_context.schema.json",
  "title": "ALP Multi-Modal Asset Context Object",
  "type": "object",
  "required": ["id", "asset_type", "mime_type", "digest"],
  "properties": {
    "id": { "type": "string" },
    "asset_type": { "type": "string" },
    "mime_type": { "type": "string" },
