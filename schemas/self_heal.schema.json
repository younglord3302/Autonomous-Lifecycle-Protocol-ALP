{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://alp-protocol.org/schemas/self_heal.schema.json",
  "title": "ALP Self-Healing AST Patch Object",
  "type": "object",
  "required": ["id", "target_file", "diagnosis"],
  "properties": {
    "id": { "type": "string" },
    "target_file": { "type": "string" },
    "diagnosis": { "type": "string" },
    "patch": { "type": "string" },
    "applied": { "type": "boolean" },
    "description": { "type": "string" }
  }
}
