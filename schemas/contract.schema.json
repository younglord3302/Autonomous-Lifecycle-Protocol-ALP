{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://alp-protocol.org/schemas/contract.schema.json",
  "title": "ALP Contract Object",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "description": { "type": "string" },
    "from": { "type": "string" },
    "to": { "type": "string" },
    "allows": { "type": "array", "items": { "type": "string" } },
    "denies": { "type": "array", "items": { "type": "string" } }
  }
}
