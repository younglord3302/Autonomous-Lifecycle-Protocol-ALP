{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://alp-protocol.org/schemas/formal_proof.schema.json",
  "title": "ALP Formal Verification & TLA+ Proof Object",
  "type": "object",
  "required": ["id", "target_spec", "deadlock_free"],
  "properties": {
    "id": { "type": "string" },
    "target_spec": { "type": "string" },
    "deadlock_free": { "type": "boolean" },
    "invariants_satisfied": { "type": "number" },
    "tla_spec_hash": { "type": "string" },
    "description": { "type": "string" }
  }
}
